<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        :root {
  --font-sans: Arial, sans-serif;

  --color-text-primary: #111;
  --color-text-secondary: #666;
  --color-text-tertiary: #999;

  --color-background-primary: #ffffff;
  --color-background-secondary: #f5f5f5;
  --color-background-danger: #ffe5e5;

  --color-border-primary: #6366f1;
  --color-border-secondary: #ddd;
  --color-border-tertiary: #eee;
  --color-border-danger: #ff4d4d;

  --color-text-danger: #ff4d4d;

  --border-radius-md: 8px;
  --border-radius-lg: 12px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font-sans); }
#app { max-width: 560px; margin: 0 auto; padding: 2rem 1rem; }
.app-header { margin-bottom: 2rem; }
.app-header h1 { font-size: 22px; font-weight: 500; color: var(--color-text-primary); }
.app-header p { font-size: 14px; color: var(--color-text-secondary); margin-top: 4px; }
.input-row { display: flex; gap: 8px; margin-bottom: 1.5rem; }
.input-row input { flex: 1; height: 40px; padding: 0 14px; font-size: 15px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); background: var(--color-background-primary); color: var(--color-text-primary); outline: none; transition: border-color 0.15s; }
.input-row input:focus { border-color: var(--color-border-primary); box-shadow: 0 0 0 3px rgba(99,102,241,0.08); }
.input-row input::placeholder { color: var(--color-text-tertiary); }
.add-btn { height: 40px; padding: 0 18px; border-radius: var(--border-radius-md); border: none; background: var(--color-text-primary); color: var(--color-background-primary); font-size: 14px; font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: opacity 0.15s; white-space: nowrap; }
.add-btn:hover { opacity: 0.85; }
.add-btn i { font-size: 16px; }
.filters { display: flex; gap: 6px; margin-bottom: 1.25rem; }
.filter-btn { padding: 5px 14px; border-radius: 20px; border: 0.5px solid var(--color-border-secondary); background: transparent; color: var(--color-text-secondary); font-size: 13px; cursor: pointer; transition: all 0.15s; }
.filter-btn.active { background: var(--color-text-primary); color: var(--color-background-primary); border-color: var(--color-text-primary); }
.stats { display: flex; gap: 10px; margin-bottom: 1.5rem; }
.stat { flex: 1; background: var(--color-background-secondary); border-radius: var(--border-radius-md); padding: 10px 14px; }
.stat-val { font-size: 20px; font-weight: 500; color: var(--color-text-primary); }
.stat-lbl { font-size: 12px; color: var(--color-text-secondary); margin-top: 2px; }
.task-list { display: flex; flex-direction: column; gap: 6px; }
.task-item { display: flex; align-items: center; gap: 10px; padding: 12px 14px; background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); transition: border-color 0.15s; }
.task-item:hover { border-color: var(--color-border-secondary); }
.task-item.done { background: var(--color-background-secondary); }
.check-btn { width: 22px; height: 22px; border-radius: 50%; border: 1.5px solid var(--color-border-secondary); background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.15s; color: transparent; }
.task-item.done .check-btn { background: var(--color-text-primary); border-color: var(--color-text-primary); color: var(--color-background-primary); }
.check-btn i { font-size: 13px; }
.task-text { flex: 1; font-size: 15px; color: var(--color-text-primary); transition: all 0.15s; cursor: pointer; }
.task-item.done .task-text { color: var(--color-text-tertiary); text-decoration: line-through; }
.del-btn { width: 28px; height: 28px; border-radius: var(--border-radius-md); border: none; background: transparent; color: var(--color-text-tertiary); cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transition: all 0.15s; }
.task-item:hover .del-btn { opacity: 1; }
.del-btn:hover { background: var(--color-background-danger); color: var(--color-text-danger); }
.del-btn i { font-size: 15px; }
.empty { text-align: center; padding: 2.5rem 0; color: var(--color-text-tertiary); font-size: 14px; }
.empty i { font-size: 32px; display: block; margin-bottom: 8px; }
.clear-btn { margin-top: 1.25rem; width: 100%; padding: 9px; border-radius: var(--border-radius-md); border: 0.5px solid var(--color-border-secondary); background: transparent; color: var(--color-text-secondary); font-size: 13px; cursor: pointer; transition: all 0.15s; }
.clear-btn:hover { background: var(--color-background-danger); color: var(--color-text-danger); border-color: var(--color-border-danger); }
</style>
</head>
<body>
    
<div id="app">
  <h2 class="sr-only">Personal to-do list app</h2>
  <div class="app-header">
    <h1>My tasks</h1>
    <p id="date-label"></p>
  </div>

  <div class="input-row">
    <input type="text" id="taskInput" placeholder="Add a new task…" />
    <button class="add-btn" id="addBtn"><i class="ti ti-plus" aria-hidden="true"></i> Add</button>
  </div>

  <div class="stats">
    <div class="stat"><div class="stat-val" id="s-total">0</div><div class="stat-lbl">Total</div></div>
    <div class="stat"><div class="stat-val" id="s-done">0</div><div class="stat-lbl">Done</div></div>
    <div class="stat"><div class="stat-val" id="s-left">0</div><div class="stat-lbl">Remaining</div></div>
  </div>

  <div class="filters">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="active">Active</button>
    <button class="filter-btn" data-filter="done">Done</button>
  </div>

  <div class="task-list" id="taskList"></div>

  <button class="clear-btn" id="clearDone" style="display:none"><i class="ti ti-trash" aria-hidden="true"></i> Clear completed</button>
  
<script>
const input = document.getElementById('taskInput');
const addBtn = document.getElementById('addBtn');
const listEl = document.getElementById('taskList');
const clearBtn = document.getElementById('clearDone');

let tasks = JSON.parse(localStorage.getItem('tasks')) || [];
let filter = 'all';

document.getElementById('date-label').textContent = new Date().toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' });

function save() { localStorage.setItem('tasks', JSON.stringify(tasks)); }

function addTask() {
  const text = input.value.trim();
  if (!text) return;
  tasks.unshift({ id: Date.now(), text, done: false });
  input.value = '';
  save();
  render();
}

function toggleTask(id) {
  const t = tasks.find(t => t.id === id);
  if (t) { t.done = !t.done; save(); render(); }
}

function deleteTask(id) {
  tasks = tasks.filter(t => t.id !== id);
  save();
  render();
}

function render() {
  const visible = tasks.filter(t =>
    filter === 'all' ? true : filter === 'done' ? t.done : !t.done
  );

  const done = tasks.filter(t => t.done).length;
  document.getElementById('s-total').textContent = tasks.length;
  document.getElementById('s-done').textContent = done;
  document.getElementById('s-left').textContent = tasks.length - done;
  clearBtn.style.display = done > 0 ? 'block' : 'none';

  if (visible.length === 0) {
    const msg = filter === 'done' ? 'No completed tasks yet' : filter === 'active' ? 'All caught up!' : 'No tasks yet — add one above';
    listEl.innerHTML = `<div class="empty"><i class="ti ti-checkbox" aria-hidden="true"></i>${msg}</div>`;
    return;
  }

  listEl.innerHTML = visible.map(t => `
    <div class="task-item${t.done ? ' done' : ''}" data-id="${t.id}">
      <button class="check-btn" onclick="toggleTask(${t.id})" aria-label="${t.done ? 'Mark incomplete' : 'Mark complete'}">
        <i class="ti ti-check" aria-hidden="true"></i>
      </button>
      <span class="task-text" onclick="toggleTask(${t.id})">${t.text}</span>
      <button class="del-btn" onclick="deleteTask(${t.id})" aria-label="Delete task">
        <i class="ti ti-trash" aria-hidden="true"></i>
      </button>
    </div>
  `).join('');
}

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    filter = btn.dataset.filter;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    render();
  });
});

clearBtn.addEventListener('click', () => {
  tasks = tasks.filter(t => !t.done);
  save();
  render();
});

addBtn.addEventListener('click', addTask);
input.addEventListener('keydown', e => e.key === 'Enter' && addTask());

render();
</script>
</div>
</body>

</html>
